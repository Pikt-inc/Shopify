# Shopify store credentials used by examples and local smoke tests.
SHOPIFY_SHOP_DOMAIN=example.myshopify.com
SHOPIFY_ACCESS_TOKEN=replace-with-shopify-admin-access-token
SHOPIFY_API_VERSION=2025-10

# Optional example inputs.
SHOPIFY_VARIANT_ID=gid://shopify/ProductVariant/1234567890

# Optional integration-test credentials used by the GitHub workflow when secrets exist.
TEST_SHOPIFY_SHOP_DOMAIN=example.myshopify.com
TEST_SHOPIFY_ACCESS_TOKEN=replace-with-test-shopify-admin-access-token
TEST_SHOPIFY_API_VERSION=2025-10
